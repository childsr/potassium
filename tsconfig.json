{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "esModuleInterop": true,
    "declaration": true,
    "incremental": true,
    "target": "es2022",
    "noImplicitAny": true,
    "strict": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "outDir": "dist",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "test/**/*.ts"
  ]
}
