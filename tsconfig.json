{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "esModuleInterop": true,
    "declaration": true,
    "incremental": true,
    "noImplicitAny": true,
    "strict": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "outDir": "dist",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "test/**/*.ts"
  ]
}